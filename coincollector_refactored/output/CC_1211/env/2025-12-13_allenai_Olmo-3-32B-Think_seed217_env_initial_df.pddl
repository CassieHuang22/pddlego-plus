(define (domain exploration) (:types location direction) (:predicates (at ?l - location) (door-closed ?loc1 - location ?loc2 - location ?dir - direction)) (:action open-door :parameters (?loc1 - location ?loc2 - location ?dir - direction) :effect (not (door-closed ?loc1 ?loc2 ?dir))) (:action move :parameters (?from - location ?to - location ?dir - direction) :precondition (and (at ?from) (not (door-closed ?from ?to ?dir))) :effect (and (at ?to) (not (at ?from)))) )