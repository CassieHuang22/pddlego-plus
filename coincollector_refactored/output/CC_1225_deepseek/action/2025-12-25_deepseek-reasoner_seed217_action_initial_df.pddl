(define (domain exploration)
  (:requirements :strips)
  (:types location direction)
  (:predicates 
    (at ?l - location)
    (adjacent ?from ?to - location ?d - direction)
    (closed ?from ?to - location ?d - direction)
    (connected ?from ?to - location ?d - direction)
  )
  (:action open-door
    :parameters (?loc1 ?loc2 - location ?dir - direction)
    :precondition (and (at ?loc1) (adjacent ?loc1 ?loc2 ?dir) (closed ?loc1 ?loc2 ?dir))
    :effect (and (not (closed ?loc1 ?loc2 ?dir)) (connected ?loc1 ?loc2 ?dir))
  )
  (:action move
    :parameters (?from ?to - location ?dir - direction)
    :precondition (and (at ?from) (connected ?from ?to ?dir))
    :effect (and (not (at ?from)) (at ?to))
  )
)